# Auto detect text files and perform LF normalization
* text=auto

# HTML
*.html text eol=lf

# CSS
*.css text eol=lf

# JavaScript
*.js text eol=lf

# JSON
*.json text eol=lf

# Markdown
*.md text eol=lf

# SCSS
*.scss text eol=lf

# Images
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.svg text eol=lf
*.webp binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
